@{
    ViewData["Title"] = "Home Page";
    ViewBag.Estado = false;
}

<div class="text-center">
    <h1 class="display-4">Equação de 2º Grau</h1>
    <img src="https://www.casadasciencias.org/storage/app/uploads/public/5e0/df9/6ae/5e0df96ae8108558117106.png" alt="imagem com a fórmula resolvente" width="200"/>
</div>

<form method="post">
<p>Parâmetros da equação do 2º Grau</p>
<p>
    A: <input type="number" name="a" required/> <br />
    B: <input type="number" name="b" required/> <br />
    C: <input type="number" name="c" required/> <br />
</p>
<input type="submit" value="Calcular"/>
</form>

@*resposta do Controller*@

<div>
    <p>@ViewBag.Erro</p>
    <p>@ViewBag.X1</p><br />
    <p>@ViewBag.X2</p><br />
</div>